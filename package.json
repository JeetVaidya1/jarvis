{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "Jeet's personal AI agent — secure, local, Telegram-controlled",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc -p dashboard/tsconfig.json",
    "start": "node dist/index.js",
    "dashboard": "tsx watch dashboard/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dashboard\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@polymarket/clob-client": "^5.8.0",
    "better-sqlite3": "^12.8.0",
    "express": "^4.21.0",
    "systeminformation": "^5.22.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "googleapis": "^171.4.0",
    "grammy": "^1.35.0",
    "node-cron": "^3.0.3",
    "playwright": "^1.58.2",
    "sqlite-vec": "^0.1.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
